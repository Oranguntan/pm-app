const colExt=collection(db,'extensions');
const PIE=['#4f8ef7','#2ecc8a','#f5a623','#f05252','#a78bfa','#e879f9','#34d399','#fb923c'];

let projects=[],users=[],extensions=[];
let me=null,editId=null,detailId=null,extProjId=null,approvingExtId=null;
let activeFilter='הכל',charts={},regRole='ramd',formBlockers=[];

// ── AUTH ──
// selectRegRole removed - using person-based registration

// Reg state
let regBranch='binui', regRank='raen', regPersonId=null;

window.selectRegBranch=b=>{
  regBranch=b;
  document.getElementById('reg-branch-binui')?.classList.toggle('sel',b==='binui');
  document.getElementById('reg-branch-tashtiot')?.classList.toggle('sel',b==='tashtiot');
  regPersonId=null;
  renderRegRoleList();
  updateRegPreview();
};

window.selectRegRank=r=>{
  regRank=r;
  ['raen','ramd','ramah'].forEach(x=>document.getElementById('reg-rank-'+x)?.classList.toggle('sel',x===r));
};

function renderRegRoleList(){
  const list=document.getElementById('reg-role-list');
  if(!list) return;
  const branchFilter=regBranch==='binui'?'בינוי':'תשתיות';
  const filtered=persons.filter(p=>p.branch===branchFilter||p.branch===regBranch);
  if(!filtered.length){
    list.innerHTML='<div style="padding:10px;font-size:12px;color:var(--text3);text-align:center">אין תפקידים עדיין — הוסף חדש למטה</div>';
    return;
  }
  list.innerHTML=filtered.map(p=>{
    const isReg=users.some(u=>u.personId===p.id);
    const isSel=regPersonId===p.id;
    return`<div onclick="selectRegPerson('${p.id}')" style="padding:10px 12px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);background:${isSel?'rgba(79,142,247,0.12)':'transparent'}">
      <span style="font-size:13px;color:${isSel?'var(--accent)':'var(--text)'};font-weight:${isSel?700:400}">${p.fullTitle}${isSel?' ✓':''}</span>
      <span style="font-size:10px;color:${isReg?'var(--text3)':'var(--green)'}">${isReg?'תפוס':'פנוי'}</span>
    </div>`;
  }).join('');
}

window.selectRegPerson=id=>{
  regPersonId=id;
  renderRegRoleList();
  updateRegPreview();
};

function updateRegPreview(){
  const preview=document.getElementById('reg-preview');
  const text=document.getElementById('reg-preview-text');
  if(!preview||!text) return;
  if(regPersonId){
    const p=persons.find(x=>x.id===regPersonId);
    if(p){preview.style.display='block';text.textContent=p.fullTitle;}
  } else {
    preview.style.display='none';
  }
}

window.addNewRoleFromReg=async()=>{
  const name=document.getElementById('reg-new-role-name').value.trim();
  if(!name){showToast('⚠️ נא להזין שם');return;}
  const branch=regBranch==='binui'?'בינוי':'תשתיות';
  const rankMap={'raen':'רע"ן','ramd':'רמ"ד','ramah':'רמ"ח'};
  const rank=rankMap[regRank]||'רמ"ד';
  const fullTitle=`${rank} — ${name}`;
  const ref=await addDoc(colPersons,{name,branch,rank,fullTitle,createdAt:new Date().toISOString()});
  document.getElementById('reg-new-role-name').value='';
  regPersonId=ref.id;
  showToast('✅ תפקיד נוסף');
  setTimeout(()=>{renderRegRoleList();updateRegPreview();},500);
};

window.doRegister=async()=>{
  clearAuthError('reg-error');
  const email=document.getElementById('reg-email').value.trim();
  const pass=document.getElementById('reg-pass').value;
  const pass2=document.getElementById('reg-pass2').value;
  if(!regPersonId){showAuthError('reg-error','נא לבחור תפקיד מהרשימה');return;}
  if(!email){showAuthError('reg-error','נא להזין אימייל');return;}
  if(pass.length<6){showAuthError('reg-error','הסיסמא חייבת לפחות 6 תווים');return;}
  if(pass!==pass2){showAuthError('reg-error','הסיסמאות אינן תואמות');return;}
  const person=persons.find(x=>x.id===regPersonId);
  if(!person){showAuthError('reg-error','תפקיד לא נמצא');return;}
  try{
    const cred=await createUserWithEmailAndPassword(auth,email,pass);
    // Map rank to system role
    const roleMap={'רע"ן':'raen','רמ"ד':'ramd','רמ"ח':'ramah','קמ"ד':'kamd'};
    const sysRole=roleMap[person.rank]||'ramd';
    await addDoc(colUsers,{uid:cred.user.uid,name:person.fullTitle,role:sysRole,email,personId:regPersonId,branch:regBranch,createdAt:new Date().toISOString()});
    showToast('✅ החשבון נוצר בהצלחה');
  }catch(e){
    const msgs={'auth/email-already-in-use':'האימייל הזה כבר רשום במערכת','auth/invalid-email':'כתובת אימייל לא תקינה','auth/weak-password':'הסיסמא חלשה מדי'};
    showAuthError('reg-error',msgs[e.code]||'שגיאה ביצירת החשבון');
  }
};

window.doLogin=async()=>{
  clearAuthError('login-error');
  const email=document.getElementById('login-email').value.trim();
  const pass=document.getElementById('login-pass').value;
  if(!email||!pass){showAuthError('login-error','נא למלא אימייל וסיסמא');return;}
  try{
    await signInWithEmailAndPassword(auth,email,pass);
  }catch(e){
    const msgs={'auth/user-not-found':'משתמש לא נמצא','auth/wrong-password':'סיסמא שגויה','auth/invalid-credential':'אימייל או סיסמא שגויים','auth/too-many-requests':'יותר מדי ניסיונות'};
    showAuthError('login-error',msgs[e.code]||'שגיאה בכניסה');
  }
};

window.gotoLogin=()=>{document.getElementById('screen-register').classList.add('hidden');document.getElementById('screen-login').classList.remove('hidden');};
window.gotoRegister=()=>{document.getElementById('screen-login').classList.add('hidden');document.getElementById('screen-register').classList.remove('hidden');renderRegRoleList();};
function showAuthError(id,msg){
  const el=document.getElementById(id);
  el.textContent=msg;el.classList.add('show');
}
function clearAuthError(id){document.getElementById(id).classList.remove('show');}


// ── AUTH STATE ──
onAuthStateChanged(auth,async user=>{
  if(user){
    const q=query(colUsers,where('uid','==',user.uid));
    const snap=await getDocs(q);
    if(!snap.empty){
      // existing user
      me={id:snap.docs[0].id,...snap.docs[0].data()};
      enterApp();
    } else {
      // new user - show role setup
      document.getElementById('screen-login').classList.add('hidden');
      document.getElementById('screen-setup-role').classList.remove('hidden');
      // watch for user doc creation
      const unsub = onSnapshot(query(colUsers,where('uid','==',user.uid)), snap=>{
        if(!snap.empty){
          me={id:snap.docs[0].id,...snap.docs[0].data()};
          document.getElementById('screen-setup-role').classList.add('hidden');
          unsub();
          enterApp();
        }
      });
    }
  }else{
    exitApp();
  }
});

function enterApp(){
  document.getElementById('screen-register').classList.add('hidden');
  document.getElementById('screen-login').classList.add('hidden');
  document.getElementById('app').style.display='flex';
  document.getElementById('fab').style.display='flex';
  document.getElementById('user-chip').textContent=me.name;
  if(isAdmin()) document.getElementById('admin-badge').style.display='flex';
  else document.getElementById('admin-badge').style.display='none';
  if(me.role==='ramah') document.getElementById('nav-pending').style.display='flex';
  render();
  // Request notifications after short delay so UI is ready
  setTimeout(requestAndRegisterNotif, 1500);
  startNotifsListener();
  setTimeout(migrateOldExtensions, 2000);
}

async function requestAndRegisterNotif(){
  if(!('Notification' in window)) return;
  try {
    // Always request - even if previously denied, show our modal
    if(Notification.permission === 'default'){
      // Show our own prompt first
      showNotifPrompt();
    } else if(Notification.permission === 'granted'){
      await registerFCMToken();
      // Update settings toggle
      const toggle = document.getElementById('notif-toggle');
      if(toggle) toggle.checked = true;
    } else {
      // Denied - show message in settings
      const toggle = document.getElementById('notif-toggle');
      if(toggle) toggle.checked = false;
    }
  } catch(e){ console.log('Notif request error:', e); }
}


function showInAppNotif(title, body){
  // Remove existing if any
  document.getElementById('in-app-notif')?.remove();
  const div=document.createElement('div');
  div.id='in-app-notif';
  div.style.cssText='position:fixed;top:70px;right:12px;left:12px;background:#1a1f2e;border:1px solid rgba(79,142,247,0.4);border-radius:10px;padding:12px 14px;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,0.5);animation:slideDown 0.3s ease';
  div.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px">
    <div>
      <div style="font-size:13px;font-weight:700;color:#f0f2f7;margin-bottom:2px">🔔 ${title}</div>
      <div style="font-size:12px;color:#8892a8">${body}</div>
    </div>
    <div onclick="document.getElementById('in-app-notif').remove()" style="color:#5a6278;cursor:pointer;font-size:18px;line-height:1">×</div>
  </div>`;
  document.body.appendChild(div);
  setTimeout(()=>document.getElementById('in-app-notif')?.remove(), 6000);
}

function showNotifPrompt(){
  // Show a nice in-app prompt before triggering browser dialog
  const div = document.createElement('div');
  div.id = 'notif-prompt';
  div.style.cssText = 'position:fixed;bottom:80px;right:16px;left:16px;background:#1a1f2e;border:1px solid rgba(79,142,247,0.4);border-radius:12px;padding:16px;z-index:9999;box-shadow:0 8px 32px rgba(0,0,0,0.5)';
  div.innerHTML = `
    <div style="font-size:20px;margin-bottom:6px">🔔</div>
    <div style="font-size:14px;font-weight:700;color:#f0f2f7;margin-bottom:4px">אפשר התראות</div>
    <div style="font-size:12px;color:#8892a8;margin-bottom:12px">קבל התראות על פרויקטים, חריגות והעברות בעלות גם כשהאפליקציה סגורה</div>
    <div style="display:flex;gap:8px">
      <button onclick="doEnableNotif()" style="flex:1;padding:9px;background:#4f8ef7;border:none;border-radius:8px;color:#fff;font-family:'Heebo',sans-serif;font-size:13px;font-weight:700;cursor:pointer">אפשר התראות</button>
      <button onclick="document.getElementById('notif-prompt').remove()" style="padding:9px 14px;background:var(--bg3);border:1px solid var(--border2);border-radius:8px;color:var(--text2);font-family:'Heebo',sans-serif;font-size:13px;cursor:pointer">אחר כך</button>
    </div>`;
  document.body.appendChild(div);
}

window.doEnableNotif = async () => {
  const prompt = document.getElementById('notif-prompt');
  if(prompt) prompt.remove();
  const perm = await Notification.requestPermission();
  if(perm === 'granted'){
    await registerFCMToken();
    const toggle = document.getElementById('notif-toggle');
    if(toggle) toggle.checked = true;
    localStorage.setItem('notif_enabled', 'true');
    showToast('✅ התראות הופעלו!');
  } else {
    showToast('⚠️ לא אושרו התראות — ניתן לאפשר בהגדרות הדפדפן');
  }
};

function exitApp(){
  me=null;
  document.getElementById('app').style.display='none';
  document.getElementById('fab').style.display='none';
  document.getElementById('nav-pending').style.display='none';
  document.getElementById('screen-setup-role').classList.add('hidden');
  document.getElementById('screen-login').classList.remove('hidden');
}

// ── NOTIFICATIONS ──
async function requestNotifPermission(){
  if(!('Notification'in window)) return;
  if(Notification.permission==='granted') await registerFCMToken();
}

async function registerFCMToken(){
  try{
    const messaging=getMessaging(fbApp);
    const swReg=await navigator.serviceWorker.ready;
    const token=await getToken(messaging,{vapidKey:VAPID_KEY,serviceWorkerRegistration:swReg});
    if(!token||!me) return;
    const q=query(collection(db,'fcmTokens'),where('userId','==',me.id),where('token','==',token));
    const snap=await getDocs(q);
    if(snap.empty) await addDoc(collection(db,'fcmTokens'),{userId:me.id,userName:me.name,token,createdAt:new Date().toISOString()});
    onMessage(messaging,payload=>{
      const{title,body}=payload.notification||{};
      if(title){
        // Show in-app notification banner
        showInAppNotif(title, body||'');
      }
    });
  }catch(e){console.log('FCM:',e.message);}
}


// ── NOTIFICATIONS SYSTEM ──
const colNotifs = collection(db,'notifications');
let myNotifs = [], unreadCount = 0;

function startNotifsListener(){
  if(!me) return;
  onSnapshot(query(colNotifs, where('toUserId','==',me.id)), snap=>{
    myNotifs=snap.docs.map(d=>({id:d.id,...d.data()})).sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));
    unreadCount=myNotifs.filter(n=>!n.read).length;
    updateNotifBadge();
    if(document.getElementById('page-notifs')?.classList.contains('active')) renderNotifsList();
  });
}

function updateNotifBadge(){
  const nb=document.getElementById('nav-notifs'); if(!nb) return;
  nb.querySelector('.nav-bdg')?.remove();
  const lbl=document.getElementById('notif-nav-lbl');
  if(unreadCount>0){
    const dot=document.createElement('div');dot.className='nav-bdg';
    dot.style.cssText='position:absolute;top:2px;left:6px;width:8px;height:8px;border-radius:50%;background:#f05252;border:2px solid var(--bg)';
    nb.style.position='relative';nb.appendChild(dot);
    if(lbl) lbl.textContent=`התראות (${unreadCount})`;
  } else { if(lbl) lbl.textContent='התראות'; }
}

function renderNotifsList(){
  const el=document.getElementById('notifs-list'); if(!el) return;
  if(!myNotifs.length){el.innerHTML='<div class="empty-state"><div class="empty-icon">🔔</div><div>אין התראות</div></div>';return;}
  el.innerHTML=myNotifs.map(n=>{
    const canApprove=isAdmin()||me?.role==='ramah'||me?.role==='raen';
    const isExt=canApprove&&n.title&&(n.title.includes('דחיית')||n.title.includes('דחייה'));
    const ext=isExt&&n.projectId?(extensions||[]).find(e=>e.projectId===n.projectId&&e.status==='pending'):null;
    const btns=ext?`<div style="display:flex;gap:6px;margin-top:8px">
      <button onclick="event.stopPropagation();quickApprove('${ext.id}')" style="flex:1;padding:7px;background:rgba(46,204,138,0.15);border:1px solid rgba(46,204,138,0.3);border-radius:6px;color:var(--green);font-family:'Heebo',sans-serif;font-size:12px;font-weight:700;cursor:pointer">✅ אשר</button>
      <button onclick="event.stopPropagation();quickReject('${ext.id}')" style="flex:1;padding:7px;background:rgba(240,82,82,0.12);border:1px solid rgba(240,82,82,0.25);border-radius:6px;color:var(--red);font-family:'Heebo',sans-serif;font-size:12px;font-weight:700;cursor:pointer">❌ דחה</button>
    </div>`:'';
    return `<div class="notif-item ${n.read&&!btns?'':'unread'}" onclick="handleNotifClick('${n.id}','${n.projectId||''}')">
      <div class="notif-icon">${n.icon||'🔔'}</div>
      <div class="notif-content">
        <div class="notif-title">${n.title||''}</div>
        <div class="notif-body">${n.body||''}</div>
        <div class="notif-time">${timeSince(n.createdAt)}</div>
        ${btns}
      </div>
      ${!n.read?'<div style="width:8px;height:8px;border-radius:50%;background:var(--accent);flex-shrink:0;margin-top:4px"></div>':''}
    </div>`;
  }).join('');
}

window.handleNotifClick=async(nid,pid)=>{
  await updateDoc(doc(db,'notifications',nid),{read:true});
  if(pid){switchPage('projects');setTimeout(()=>{if(projects.find(x=>x.id===pid))openDetail(pid);},300);}
};
window.markAllRead=async()=>{await Promise.all(myNotifs.filter(n=>!n.read).map(n=>updateDoc(doc(db,'notifications',n.id),{read:true})));};
function markNotifsRead(){myNotifs.filter(n=>!n.read).forEach(n=>updateDoc(doc(db,'notifications',n.id),{read:true}));}
function timeSince(ds){if(!ds)return '';const d=Math.floor((Date.now()-new Date(ds))/1000);if(d<60)return 'עכשיו';if(d<3600)return `לפני ${Math.floor(d/60)} דקות`;if(d<86400)return `לפני ${Math.floor(d/3600)} שעות`;return `לפני ${Math.floor(d/86400)} ימים`;}
async function sendNotif(uid,{icon,title,body,projectId}){if(!uid||uid===me?.id)return;await addDoc(colNotifs,{toUserId:uid,icon:icon||'🔔',title,body:body||'',projectId:projectId||'',read:false,createdAt:new Date().toISOString()});}
async function sendNotifToMany(ids,n){await Promise.all([...new Set(ids.filter(id=>id&&id!==me?.id))].map(id=>sendNotif(id,n)));}
function getAdminUserIds(){return users.filter(u=>ADMIN_EMAILS.includes(u.email)).map(u=>u.id);}
function getRaenUserIds(){return users.filter(u=>u.role==='raen'||u.role==='ramah').map(u=>u.id);}
function getUserIdByPersonTitle(t){if(!t)return null;const u=users.find(u=>{const p=persons.find(px=>px.id===u.personId);return p?.fullTitle===t||u.name===t;});return u?.id||null;}
window.quickApprove=async(eid)=>{
  const e=extensions.find(x=>x.id===eid);if(!e)return;
  const fmap={'tikhnun':'msTikhnunEnd','bitsuStart':'msBitsuStart','bitsuEnd':'msBitsuEnd','stageDue':'stageDue'};
  await updateDoc(doc(db,'extensions',eid),{status:'approved',approvedBy:me.name,approvedAt:new Date().toISOString()});
  await updateDoc(doc(db,'projects',e.projectId),{[fmap[e.milestone||'stageDue']||'stageDue']:e.newDate,updatedAt:new Date().toISOString()});
  const proj=projects.find(x=>x.id===e.projectId);
  await sendNotif(e.requesterId,{icon:'✅',title:'בקשת הדחייה אושרה',body:`אושר ע"י ${me.name} — "${proj?.name||''}"`,projectId:e.projectId});
  showToast('✅ אושר');renderNotifsList();
};
window.quickReject=async(eid)=>{
  const e=extensions.find(x=>x.id===eid);if(!e)return;
  await updateDoc(doc(db,'extensions',eid),{status:'rejected',approvedBy:me.name,approvedAt:new Date().toISOString()});
  const proj=projects.find(x=>x.id===e.projectId);
  await sendNotif(e.requesterId,{icon:'❌',title:'בקשת הדחייה נדחתה',body:`נדחה ע"י ${me.name} — "${proj?.name||''}"`,projectId:e.projectId});
  showToast('❌ נדחה');renderNotifsList();
};
async function migrateOldExtensions(){
  try{
    const admin=users.find(u=>u.email==='gabyop2014@gmail.com');if(!admin)return;
    if(localStorage.getItem('ext_mgr_v3'))return;
    const snap=await getDocs(query(colExt));let cnt=0;
    for(const d of snap.docs){
      const e=d.data();const proj=projects.find(x=>x.id===e.projectId);
      const ex=await getDocs(query(colNotifs,where('toUserId','==',admin.id),where('projectId','==',e.projectId)));
      if(ex.empty){
        await addDoc(colNotifs,{toUserId:admin.id,icon:'📋',title:'בקשת דחיית תאריך',
          body:`${e.requesterName||'משתמש'} ביקש לדחות תאריך של "${proj?.name||e.projectId}" ל-${fmtD(e.newDate)}${e.reason?' — '+e.reason:''}`,
          projectId:e.projectId||'',read:false,createdAt:e.requestedAt||new Date().toISOString()});cnt++;
      }
    }
    localStorage.setItem('ext_mgr_v3','true');
    if(cnt>0)showToast(`🔔 ${cnt} בקשות ישנות נוספו`);
  }catch(e){console.log(e);}
}

// ── FIRESTORE ──
onSnapshot(colUsers,snap=>{users=snap.docs.map(d=>({id:d.id,...d.data()}));if(me) render();});
onSnapshot(colProjects,snap=>{projects=snap.docs.map(d=>({id:d.id,...d.data()}));if(me){render();}});
onSnapshot(colExt,snap=>{extensions=snap.docs.map(d=>({id:d.id,...d.data()}));updatePendingBadge();if(me) renderPending();});

function updatePendingBadge(){
  const n=extensions.filter(e=>e.status==='pending').length;
  const btn=document.getElementById('nav-pending');
  btn.querySelector('.nb-badge')?.remove();
  if(n>0&&me?.role==='ramah'){const b=document.createElement('div');b.className='nb-badge';b.textContent=n;btn.appendChild(b);}
}

// ── HELPERS ──
window.setToggle=(gid,val,btn)=>{document.querySelectorAll(`#${gid} .toggle-btn`).forEach(b=>b.className='toggle-btn');btn.classList.add('sel-gray');const el=document.getElementById(gid.replace('tg-','f-'));if(el)el.value=val;};
window.setToggle3=(gid,val,color,btn)=>{document.querySelectorAll(`#${gid} .toggle-btn`).forEach(b=>b.className='toggle-btn');btn.classList.add(`sel-${color}`);const el=document.getElementById(gid.replace('tg-','f-'));if(el)el.value=val;};
window.addBlocker=()=>{const inp=document.getElementById('blocker-input');const txt=inp.value.trim();if(!txt)return;formBlockers.push(txt);inp.value='';renderFormBlockers();};
window.removeBlocker=i=>{formBlockers.splice(i,1);renderFormBlockers();};
function renderFormBlockers(){document.getElementById('blockers-list').innerHTML=formBlockers.map((b,i)=>`<div class="blocker-item"><span class="blocker-text">${b}</span><button class="blocker-del" onclick="removeBlocker(${i})">×</button></div>`).join('');}
function myProjects(){
  if(isAdmin()||me?.role==='ramah') return projects;
  // Find this user's person record to get their fullTitle
  const myPerson = persons.find(p=>p.id===me?.personId);
  const myTitle = myPerson?.fullTitle || me?.name || '';
  return projects.filter(p=>
    p.ownerId===me?.id ||
    (myTitle && p.kapt===myTitle) ||
    (myTitle && p.integrator===myTitle)
  );
}
function daysDiff(ds){if(!ds)return null;const t=new Date();t.setHours(0,0,0,0);return Math.round((t-new Date(ds))/86400000);}
function daysLabel(ds){const d=daysDiff(ds);if(d===null)return{text:'—',cls:'bg-gray'};if(d>0)return{text:`חריגה ${d} ימים`,cls:'bg-red'};if(d===0)return{text:'היום!',cls:'bg-amber'};return{text:`נותרו ${Math.abs(d)} ימים`,cls:'bg-green'};}
function sBadge(s){const m={'בביצוע':'bg-blue','מוקפא':'bg-purple','חריג':'bg-red','נמסר':'bg-green'};return`<span class="badge ${m[s]||'bg-gray'}">${s}</span>`;}

function fmtNum(n){if(!n||n==0)return'—';return Number(n).toLocaleString('he-IL');}
function fmtM(n){return(!n||n==0)?'—':'₪'+Number(n).toLocaleString('he-IL');}
function fmtD(ds){if(!ds)return'—';const d=new Date(ds);return`${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()}`;}
function uName(id){return users.find(x=>x.id===id)?.name||'—';}
function maurBadge(v){if(v==='הסתיים')return`<span class="badge bg-green">${v}</span>`;if(v==='בתהליך')return`<span class="badge bg-amber">${v}</span>`;return`<span class="badge bg-gray">${v||'—'}</span>`;}
function statBadge(v){
  if(v==='לא נדרש') return`<span class="badge bg-green">לא נדרש</span>`;
  if(v==='פטור רמ"ח תו"פ') return`<span class="badge bg-gray">פטור רמ"ח תו"פ</span>`;
  return`<span class="badge bg-amber">נדרש</span>`;
}
function existBadge(v){return v==='קיים'?`<span class="badge bg-green">✓ קיים</span>`:`<span class="badge bg-gray">✗ לא קיים</span>`;}
function mkPie(id,labels,data,colors){
  charts[id]?.destroy();delete charts[id];
  const ctx=document.getElementById(id);if(!ctx||!data.length)return;
  const clrs=(colors||PIE).slice(0,data.length);
  charts[id]=new Chart(ctx,{type:'doughnut',data:{labels,datasets:[{data,backgroundColor:clrs,borderWidth:2,borderColor:'#232a3b',hoverOffset:5}]},options:{responsive:true,cutout:'58%',plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>` ${c.label}: ${c.raw}`}}},animation:{duration:400}}});
  // Add legend below chart
  const legendEl=document.getElementById(id+'-legend');
  if(legendEl){
    legendEl.innerHTML=labels.map((l,i)=>`
      <div style="display:flex;align-items:center;gap:4px;font-size:9px;color:var(--text2)">
        <div style="width:8px;height:8px;border-radius:2px;background:${clrs[i]};flex-shrink:0"></div>
        <span style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:70px" title="${l}">${l}: ${data[i]}</span>
      </div>`).join('');
  }
}

// ── RENDER ──
function render(){if(!me)return;renderDash();renderProjects();renderManagers();renderDelivered();}

function projRow(p){
  const dl=daysLabel(p.stageDue);
  const hasPend=extensions.some(e=>e.projectId===p.id&&e.status==='pending');
  const cls=(p.status==='חריג'||(daysDiff(p.stageDue)||0)>0)?'exc':p.status==='מוקפא'?'frz':hasPend?'pend':'';
  const isFav=(JSON.parse(localStorage.getItem('favs')||'[]')).includes(p.id);
  return`<div class="proj-row ${cls}" style="position:relative" onclick="openDetail('${p.id}')">
    <button class="fav-btn" style="position:absolute;left:8px;top:50%;transform:translateY(-50%)" onclick="event.stopPropagation();toggleFav('${p.id}')" title="מועדף">${isFav?'❤️':'🤍'}</button>
    <div class="proj-name" style="padding-left:30px">${p.name}</div>
    <div class="proj-meta">${p.stage||'—'}${p.kapt?' · קפ"ט: '+p.kapt:''}${hasPend?' · <span style="color:var(--amber)">⏳ ממתין לאישור</span>':''}</div>
    <div class="proj-tags">${sBadge(p.status)}<span class="badge ${dl.cls}">${dl.text}</span>${p.wbs==='קיים'?'<span class="badge bg-green">WBS</span>':''}${p.emf==='קיים'?'<span class="badge bg-blue">EMF</span>':''}</div>
    <div class="proj-owner">אחראי: ${uName(p.ownerId)}</div>
  </div>`;
}

function renderDash(){
  const vp=myProjects().filter(p=>!p.delivered);
  const frozen=vp.filter(p=>p.status==='מוקפא');
  const exc=vp.filter(p=>p.status==='חריג'||(daysDiff(p.stageDue)||0)>0);
  const del=myProjects().filter(p=>p.delivered);
  document.getElementById('dash-stats').innerHTML=`
    <div class="stat"><div class="stat-val sv-blue">${vp.length}</div><div class="stat-lbl">פרויקטים פעילים</div></div>
    <div class="stat"><div class="stat-val sv-green">${del.length}</div><div class="stat-lbl">נמסרו</div></div>
    <div class="stat"><div class="stat-val sv-amber">${frozen.length}</div><div class="stat-lbl">מוקפאים</div></div>
    <div class="stat"><div class="stat-val sv-red">${exc.length}</div><div class="stat-lbl">חריגים</div></div>`;
  const notifs=vp.filter(p=>{const d=daysDiff(p.stageDue);return d!==null&&((d>=0&&d<=5)||d>0);}).slice(0,3);
  document.getElementById('notif-area').innerHTML=notifs.map(p=>{
    const d=daysDiff(p.stageDue);
    const msg=d>0?`חרג ב-<strong>${d} ימים</strong>`:d===0?`<strong>תג"ב היום!</strong>`:`נותרו <strong>${Math.abs(d)} ימים</strong>`;
    return`<div class="notif-row"><div style="font-size:16px;flex-shrink:0">🔔</div><div class="notif-txt"><strong>${p.name}</strong> — ${msg}</div></div>`;
  }).join('');
  setTimeout(()=>{
    const stg={},sts={},owners={};
    vp.forEach(p=>{stg[p.stage||'—']=(stg[p.stage||'—']||0)+1;sts[p.status]=(sts[p.status]||0)+1;const n=uName(p.ownerId);owners[n]=(owners[n]||0)+1;});
    mkPie('chart-stage',Object.keys(stg),Object.values(stg));
    mkPie('chart-status',Object.keys(sts),Object.values(sts),['#4f8ef7','#a78bfa','#f05252','#2ecc8a']);
    mkPie('chart-loc',Object.keys(owners),Object.values(owners));
    const tB=vp.reduce((s,p)=>s+(+p.budgeted||0),0),tR=vp.reduce((s,p)=>s+(+p.realized||0),0);
    if(tB>0)mkPie('chart-budget',['מומש','נותר'],[tR,Math.max(0,tB-tR)],['#2ecc8a','#2d3550']);
  },150);
  document.getElementById('frz-hdr').textContent=`מוקפאים ❄️ (${frozen.length})`;
  document.getElementById('frz-list').innerHTML=frozen.length?frozen.map(projRow).join(''):'<div style="color:var(--text3);font-size:12px;padding:6px">אין מוקפאים</div>';
}

function renderProjects(){
  const allActive=projects.filter(p=>!p.delivered);
  let vp = currentScope==='mine' ? myProjects().filter(p=>!p.delivered) : allActive;
  let data=vp;
  // Apply text search
  const searchEl=document.getElementById('proj-search');
  const q=(searchEl?.value||'').trim().toLowerCase();
  if(q){
    data=data.filter(p=>
      (p.name||'').toLowerCase().includes(q)||
      (p.base||'').toLowerCase().includes(q)||
      (p.stage||'').toLowerCase().includes(q)||
      (p.kapt||'').toLowerCase().includes(q)||
      (p.integrator||'').toLowerCase().includes(q)
    );
    const clr=document.getElementById('search-clear');
    if(clr) clr.style.display='block';
  } else {
    const clr=document.getElementById('search-clear');
    if(clr) clr.style.display='none';
  }
  if(selectedFilters.stage?.length) data=data.filter(p=>selectedFilters.stage.includes(p.stage));
  if(selectedFilters.kapt?.length) data=data.filter(p=>selectedFilters.kapt.includes(p.kapt));
  if(selectedFilters.integ?.length) data=data.filter(p=>selectedFilters.integ.includes(p.integrator));
  if(selectedFilters.status?.length) data=data.filter(p=>selectedFilters.status.includes(p.status));
  if(selectedFilters.base?.length) data=data.filter(p=>selectedFilters.base.includes(p.base));
  if(selectedFilters.fav?.length) {const favs=getFavs();data=data.filter(p=>favs.includes(p.id));}
  document.getElementById('proj-list').innerHTML=data.length?data.map(projRow).join(''):'<div class="empty-state"><div class="empty-icon">📋</div><div>אין פרויקטים תואמים</div></div>';
}

function renderPending(){
  if(me?.role!=='boss')return;
  const pending=extensions.filter(e=>e.status==='pending');
  document.getElementById('pending-list').innerHTML=pending.length?pending.map(e=>{
    const p=projects.find(x=>x.id===e.projectId);
    return`<div class="pending-card">
      <div style="font-weight:700;font-size:14px;margin-bottom:3px">${p?p.name:'—'}</div>
      <div style="font-size:11px;color:var(--text2);margin-bottom:8px">בקשה מ: <strong>${e.requesterName}</strong> · ${fmtD(e.requestedAt)}</div>
      <div class="pending-reason">${e.reason}</div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:10px">מקורי: <strong>${fmtD(e.originalDate)}</strong> → חדש: <strong style="color:var(--amber)">${fmtD(e.newDate)}</strong></div>
      <div style="display:flex;gap:7px">
        ${(me?.role==='ramah'||isAdmin())?`<button class="btn btn-primary btn-sm" onclick="openApprove('${e.id}')">✅ בחן ואשר</button>`:''}
        <button class="btn btn-danger btn-sm" onclick="quickReject('${e.id}')">❌ דחה</button>
      </div>
    </div>`;
  }).join(''):'<div class="empty-state"><div class="empty-icon">✅</div><div>אין בקשות ממתינות</div></div>';
}

function renderManagers(){
  // mgr-persons-list is handled by renderManagersPage() via Firestore listener
  // Just update the stats section
  const vp=myProjects().filter(p=>!p.delivered);
  const statsEl=document.getElementById('mgr-stats-section');
  if(statsEl && vp.length>0){
    const active=vp.length;
    const frozen=vp.filter(p=>p.status==='מוקפא').length;
    const exc=vp.filter(p=>p.status==='חריג'||(daysDiff(p.stageDue)||0)>0).length;
    statsEl.innerHTML=`<div class="cubes2" style="margin-bottom:8px">
      <div class="cube-card" style="text-align:center"><div style="font-size:22px;font-weight:700;color:var(--accent)">${active}</div><div style="font-size:11px;color:var(--text2)">פרויקטים פעילים</div></div>
      <div class="cube-card" style="text-align:center"><div style="font-size:22px;font-weight:700;color:var(--red)">${exc}</div><div style="font-size:11px;color:var(--text2)">חריגים</div></div>
    </div>`;
  } else if(statsEl){
    statsEl.innerHTML='';
  }
}

