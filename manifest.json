window.openAddModal=()=>{
  editId=null;formBlockers=[];
  document.getElementById('modal-add-title').textContent='פרויקט חדש';
  document.getElementById('edit-delete-btn').style.display='none';
  ['f-name','f-kapt','f-integrator','f-stage-due','f-start','f-end','f-est-nis','f-est-ds'].forEach(id=>document.getElementById(id).value='');
  const fb=document.getElementById('f-base');if(fb)fb.value='';
  document.getElementById('f-stage').value='';document.getElementById('f-status').value='בביצוע';
  ['f-ms-yizum-start','f-ms-yizum-end','f-ms-tikhnun-start','f-ms-tikhnun-end','f-ms-hitkashrut-start','f-ms-hitkashrut-end','f-ms-bitsu-start','f-ms-bitsu-end'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  ['tg-plan1','tg-plan2'].forEach(id=>{const btns=document.querySelectorAll(`#${id} .toggle-btn`);btns.forEach((b,i)=>{b.className='toggle-btn';if(i===0)b.classList.add('sel-gray');});});
  document.getElementById('f-plan1').value='פנימי';document.getElementById('f-plan2').value='פנימי';
  restoreToggle2yesno('tg-maur','לא קיים');restoreToggle2yesno('tg-wbs','לא קיים');restoreToggle2yesno('tg-emf','לא קיים');restoreStatutory('נדרש','נדרש');
  renderFormBlockers();
  document.getElementById('modal-add').classList.add('open');
  setTimeout(setupNumInputs,50);
};

window.saveProject=async()=>{
  const name=document.getElementById('f-name').value.trim();
  const stage=document.getElementById('f-stage').value;
  if(!name||!stage){showToast('⚠️ נא למלא שם פרויקט ושלב נוכחי');return;}
  const status=document.getElementById('f-status').value;
  const data={name,kapt:document.getElementById('f-kapt').value.trim(),integrator:document.getElementById('f-integrator').value.trim(),stage,stageDue:document.getElementById('f-stage-due').value,status,startDate:document.getElementById('f-start').value,endDate:document.getElementById('f-end').value,estNis:+(document.getElementById('f-est-nis').dataset.raw||document.getElementById('f-est-nis').value.replace(/[^0-9]/g,''))||0,estDs:+(document.getElementById('f-est-ds').dataset.raw||document.getElementById('f-est-ds').value.replace(/[^0-9]/g,''))||0,plan1:document.getElementById('f-plan1').value,plan2:document.getElementById('f-plan2').value,maur:document.getElementById('f-maur').value,wbs:document.getElementById('f-wbs').value,emf:document.getElementById('f-emf').value,statValhof:document.getElementById('f-stat-valhof')?.value||'נדרש',statValmb:document.getElementById('f-stat-valmb')?.value||'נדרש',blockers:[...formBlockers],delivered:status==='נמסר',ownerId:me.id,ownerName:me.name,base:document.getElementById('f-base')?.value||'',updatedAt:new Date().toISOString(),msYizumStart:document.getElementById('f-ms-yizum-start')?.value||'',
    msYizumEnd:document.getElementById('f-ms-yizum-end')?.value||'',
    msTikhnunStart:document.getElementById('f-ms-tikhnun-start')?.value||'',
    msTikhnunEnd:document.getElementById('f-ms-tikhnun-end')?.value||'',
    msHitkashrutStart:document.getElementById('f-ms-hitkashrut-start')?.value||'',
    msHitkashrutEnd:document.getElementById('f-ms-hitkashrut-end')?.value||'',
    msBitsuStart:document.getElementById('f-ms-bitsu-start')?.value||'',
    msBitsuEnd:document.getElementById('f-ms-bitsu-end')?.value||'',
  };
  if(!editId){data.originalStageDue=data.stageDue||'';data.createdAt=new Date().toISOString();}
  try{
    if(editId){
      // Check if actual dates changed → send notifications
      const oldP=projects.find(x=>x.id===editId);
      const actualFields=['msTikhnunActual','msBitsuStartActual','msBitsuEndActual'];
      const fieldNames={'msTikhnunActual':'סיום תכנון בפועל','msBitsuStartActual':'תחילת ביצוע בפועל','msBitsuEndActual':'סיום ביצוע בפועל'};
      const changes=actualFields.filter(f=>data[f]&&data[f]!==(oldP?.[f]||''));
      if(changes.length>0){
        const histEntry={
          date:new Date().toISOString(),
          updatedBy:me.name,
          changes:changes.map(f=>({field:fieldNames[f],oldVal:oldP?.[f]||'—',newVal:data[f]}))
        };
        data.milestoneHistory=[...(oldP?.milestoneHistory||[]),histEntry];
      }
      await updateDoc(doc(db,'projects',editId),data);
      if(changes.length>0) notifyMilestoneUpdate(data);
      showToast('✅ עודכן');
    }
    else{await addDoc(colProjects,data);showToast('✅ פרויקט נוסף');}
    closeModal('modal-add');
  }catch(e){showToast('❌ שגיאה בשמירה');}
};

window.openDetail=id=>{
  detailId=id;const p=projects.find(x=>x.id===id);if(!p)return;
  const dl=daysLabel(p.stageDue);
  const approved=extensions.filter(e=>e.projectId===id&&e.status==='approved');
  const hasPend=extensions.some(e=>e.projectId===id&&e.status==='pending');
  const canExt=!hasPend&&!p.delivered&&(me?.role==='ramah'||p.ownerId===me?.id);
  document.getElementById('detail-sticky-name').textContent=p.name;
  document.getElementById('detail-content').innerHTML=`
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px">
      <div><div style="font-size:17px;font-weight:700">${p.name}</div><div style="font-size:12px;color:var(--text2);margin-top:3px">אחראי: ${uName(p.ownerId)}</div></div>
      ${sBadge(p.status)}
    </div>
    <div class="det-section"><div class="det-section-title">🏷️ זיהוי</div>
      <div class="det-row"><span class="det-key">קפ"ט בינוי</span><span class="det-val">${p.kapt||'—'}</span></div>
      <div class="det-row"><span class="det-key">אינטגרטור</span><span class="det-val">${p.integrator||'—'}</span></div>
      <div class="det-row"><span class="det-key">מספר דרישה</span><span class="det-val">${p.reqNum||'—'}</span></div>
    </div>
    <div class="det-section"><div class="det-section-title">📍 שלב ולו"ז</div>
      <div class="det-row"><span class="det-key">שלב נוכחי</span><span class="det-val">${p.stage||'—'}</span></div>
      <div class="det-row"><span class="det-key">תג"ב מקורי</span><span class="det-val" style="color:var(--green)">${fmtD(p.originalStageDue||p.stageDue)}</span></div>
      <div class="det-row"><span class="det-key">תג"ב נוכחי</span><span class="det-val" style="color:${approved.length?'var(--amber)':'var(--text)'}">${fmtD(p.stageDue)}</span></div>
      <div class="det-row"><span class="det-key">ימי חריגה</span><span class="det-val"><span class="badge ${dl.cls}">${dl.text}</span></span></div>
      ${approved.length?`<div class="det-row"><span class="det-key">מספר דחיות</span><span class="det-val" style="color:var(--amber)">${approved.length}</span></div>`:''}
    </div>
    <div class="det-grid">
      <div class="det-mini"><div class="det-mini-val">${fmtD(p.startDate)}</div><div class="det-mini-lbl">תחילת ביצוע</div></div>
      <div class="det-mini"><div class="det-mini-val">${fmtD(p.endDate)}</div><div class="det-mini-lbl">גמר ביצוע</div></div>
    </div>
    <div class="det-section"><div class="det-section-title">💰 תקציב</div>
      <div class="det-row"><span class="det-key">אומדן ש"ח</span><span class="det-val">${fmtNum(p.estNis)}</span></div>
      <div class="det-row"><span class="det-key">אומדן ד"ס</span><span class="det-val">${p.estDs?fmtNum(p.estDs)+' ד"ס':'—'}</span></div>

    </div>
    <div class="det-section"><div class="det-section-title">📐 תכנון וסטטוסים</div>
      <div class="det-row"><span class="det-key">תכנון ראשוני</span><span class="det-val">${p.plan1||'—'}</span></div>
      <div class="det-row"><span class="det-key">תכנון מפורט</span><span class="det-val">${p.plan2||'—'}</span></div>
      <div class="det-row"><span class="det-key">סבב מאו"רים</span><span class="det-val">${maurBadge(p.maur)}</span></div>
      <div class="det-row"><span class="det-key">WBS</span><span class="det-val">${existBadge(p.wbs)}</span></div>
      <div class="det-row"><span class="det-key">EMF</span><span class="det-val">${existBadge(p.emf)}</span></div>
    </div>
    <div class="det-section"><div class="det-section-title">📋 סטטוטוריקה</div>
      <div class="det-row"><span class="det-key">ולחו"ף</span><span class="det-val">${statBadge(p.statValhof)}</span></div>
      <div class="det-row"><span class="det-key">ולמ"ב</span><span class="det-val">${statBadge(p.statValmb)}</span></div>
    </div>
    ${p.blockers&&p.blockers.length?`<div class="det-section"><div class="det-section-title">⚠️ חסמים</div>${p.blockers.map(b=>`<div class="blocker-item" style="margin-bottom:6px"><span class="blocker-text">${b}</span></div>`).join('')}</div>`:''}`;

  const existingContent2 = document.getElementById('detail-content').innerHTML;

  // Build Gantt
  const phases=[
    {key:'msYizum',name:'ייזום',color:'#4f8ef7'},
    {key:'msTikhnun',name:'תכנון',color:'#2ecc8a'},
    {key:'msHitkashrut',name:'התקשרות',color:'#f5a623'},
    {key:'msBitsu',name:'ביצוע',color:'#a78bfa'},
  ];
  const hasMilestones = phases.some(ph=>p[ph.key]);
  let ganttHtml='';
  if(hasMilestones){
    const dates=phases.flatMap(ph=>[p[ph.start],p[ph.end]]).filter(Boolean).map(d=>new Date(d));
    const minDate=new Date(Math.min(...dates.map(d=>d.getTime())));
    const maxDate=new Date(Math.max(...dates.map(d=>d.getTime())));
    minDate.setDate(1);
    const totalDays=Math.max((maxDate-minDate)/86400000+30, 90);
    const today=new Date();
    const todayPct=Math.min(100,Math.max(0,(today-minDate)/86400000/totalDays*100));
    const months=[];
    const monthYears=[];
    const cur2=new Date(minDate);
    while(cur2<=maxDate){
      months.push(cur2.toLocaleDateString('he-IL',{month:'short'}));
      monthYears.push(cur2.getFullYear());
      cur2.setMonth(cur2.getMonth()+1);
    }
    // Build year header groups
    const yearGroups={};
    monthYears.forEach(y=>{yearGroups[y]=(yearGroups[y]||0)+1;});
    const yearHeaderHtml=Object.entries(yearGroups).map(([y,count])=>
      `<div style="flex:${count};text-align:center;font-size:9px;font-weight:700;color:var(--accent);border-left:1px solid rgba(79,142,247,0.2);border-bottom:1px solid rgba(79,142,247,0.2);padding:1px 0">${y}</div>`
    ).join('');

    const monthCols=months.map(m=>`<div class="gantt-month-cell">${m}</div>`).join('');

    // Gantt: each phase has start+end bar. Red overrun if end is past today.
    const bars=phases.map(ph=>{
      const startDate=p[ph.start]?new Date(p[ph.start]):null;
      const endDate=p[ph.end]?new Date(p[ph.end]):null;
      const hasAny=startDate||endDate;

      if(!hasAny) return `<div class="gantt-row">
        <div class="gantt-name" style="color:var(--text3);font-style:italic">${ph.name}</div>
        <div class="gantt-track" style="position:relative">
          ${Array(months.length).fill('<div class="gantt-track-cell"></div>').join('')}
          <div style="position:absolute;inset:0;display:flex;align-items:center;padding:0 6px">
            <span style="font-size:9px;color:var(--text3);font-style:italic">אין תאריך</span>
          </div>
          <div class="gantt-today" style="left:${todayPct.toFixed(1)}%"></div>
        </div></div>`;

      const s=startDate||endDate;
      const e=endDate||startDate;
      const barLeft=Math.max(0,(s-minDate)/86400000/totalDays*100);
      const barWidth=Math.max(1.5,(e-s)/86400000/totalDays*100);
      const isOverdue=e>today; // end is in future (but was supposed to be done - detect via today crossing)
      const isDone=e<=today;

      let barHtml='';
      if(isOverdue){
        // Split: normal up to today, red from today to end
        const normalW=Math.max(0,(today-s)/86400000/totalDays*100);
        const redLeft=Math.max(0,(today-minDate)/86400000/totalDays*100);
        const redW=Math.max(1,(e-today)/86400000/totalDays*100);
        const days=Math.round((e-today)/86400000);
        barHtml=`
          ${normalW>0.5?`<div class="gantt-bar" style="left:${barLeft.toFixed(1)}%;width:${normalW.toFixed(1)}%;background:${ph.color};opacity:0.7;border-radius:4px 0 0 4px"><span class="gantt-bar-label">${ph.name}</span></div>`:''}
          <div style="position:absolute;left:${redLeft.toFixed(1)}%;width:${redW.toFixed(1)}%;height:18px;background:#f05252;opacity:0.9;border-radius:0 4px 4px 0;display:flex;align-items:center;justify-content:center;z-index:3">
            <span style="font-size:7px;font-weight:700;color:#fff;white-space:nowrap">+${days}י׳ ⚠</span>
          </div>`;
      } else {
        barHtml=`<div class="gantt-bar" style="left:${barLeft.toFixed(1)}%;width:${barWidth.toFixed(1)}%;background:${ph.color};opacity:0.6"><span class="gantt-bar-label">${ph.name} ✓</span></div>`;
      }

      return `<div class="gantt-row">
        <div class="gantt-name" style="color:${isOverdue?'#f05252':'var(--text3)'}">${ph.name}${isDone?' ✓':isOverdue?' ⚠':''}</div>
        <div class="gantt-track" style="position:relative">
          ${Array(months.length).fill('<div class="gantt-track-cell"></div>').join('')}
          ${barHtml}
          <div class="gantt-today" style="left:${todayPct.toFixed(1)}%"></div>
        </div>
      </div>`;
    }).join('');

    const msList=phases.map(ph=>{
      const s=p[ph.start]; const e=p[ph.end];
      return `<div class="ms-item">
        <div class="ms-left">
          <div class="ms-dot" style="background:${ph.color}"></div>
          <span class="ms-name">${ph.name}</span>
        </div>
        <div style="text-align:left;font-size:11px">
          ${s||e?`<span style="color:${ph.color}">${s?fmtD(s):'?'} ← → ${e?fmtD(e):'?'}</span>`:'<span style="color:var(--text3)">לא הוזן</span>'}
        </div>
      </div>`;
    }).join('');

    const ganttLegend=`<div class="gantt-legend">
      <div class="gantt-legend-item"><div class="gantt-legend-dot" style="background:var(--text3)"></div>הושלם</div>
      <div class="gantt-legend-item"><div class="gantt-legend-dot" style="background:var(--accent)"></div>בתהליך</div>
      <div class="gantt-legend-item"><div class="gantt-legend-dot" style="background:#f05252"></div>חריגה</div>
    </div>`;
    ganttHtml+=`<div class="gantt-section"><div class="det-section-title">📅 גאנט אבני דרך</div><div class="gantt-wrap"><div class="gantt-inner">${yearRow}${monthRow}${bars}</div></div><div class="ms-section">${msList}</div>${ganttLegend}</div>`;
  }
  const existingContent2 = document.getElementById('detail-content').innerHTML;
  document.getElementById('detail-content').innerHTML = existingContent2 + ganttHtml;
  // History
  let historyHtml='';
  if(p.milestoneHistory?.length){
    historyHtml=`<div class="gantt-section" style="margin-top:14px"><div class="det-section-title">📋 היסטוריית עדכוני תאריכים</div>${p.milestoneHistory.slice().reverse().map(h=>`<div class="hist-item" style="margin-bottom:6px"><div class="hist-date-lbl">${fmtD(h.date)} · ${h.updatedBy}</div>${h.changes.map(c=>`<div class="hist-body" style="margin-top:3px">${c.field}: <span style="color:var(--text3)">${fmtD(c.oldVal)}</span> → <span style="color:var(--accent)">${fmtD(c.newVal)}</span></div>`).join('')}</div>`).join('')}</div>`;
  }
  document.getElementById('detail-content').innerHTML += historyHtml;
}

window.addEventListener('online',()=>{document.getElementById('offline-bar').classList.remove('show');document.getElementById('sync-dot').classList.remove('off');showToast('✅ חזרת לרשת');});
window.addEventListener('offline',()=>{document.getElementById('offline-bar').classList.add('show');document.getElementById('sync-dot').classList.add('off');});
if(!navigator.onLine){document.getElementById('offline-bar').classList.add('show');document.getElementById('sync-dot').classList.add('off');}
</script>
<script>if('serviceWorker'in navigator){navigator.serviceWorker.register('/firebase-messaging-sw.js').catch(()=>{});navigator.serviceWorker.register('/sw.js').catch(()=>{});}</script>
</body>
</html>
